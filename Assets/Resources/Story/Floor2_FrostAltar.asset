  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 193f66aaf2c6fcf45966fe657458c1e9, type: 3}
  m_Name: Floor2_FrostAltar
  m_EditorClassIdentifier: 
  objectId: f2_frost_altar
  bannerText: "[Investigate] Frostsleep Altar"
  spawnFloor: 2
  spawnRoomIndex: 2
  spawnOffset: {x: -3.5, y: 2, z: 0}
  tintColor: {r: 0.78, g: 0.82, b: 0.9, a: 1}
  visualScale: {x: 1.6, y: 1}
  colliderSize: {x: 1.6, y: 1}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The altar is sheathed in thick ice; beneath it, prayers left by the church."
  - note: "\u9996\u6B21-\u5965\u65AF\u6C40\u7977\u6587"
    minCount: 1
    maxCount: 1
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "May the ice seal away evil."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "May silence cover the guilty."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "May none speak the names beneath again."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u2014 this is no sealing rite. It's a silencing rite."
  - note: "\u9996\u6B21-\u975E\u5965\u65AF\u6C40"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: Paladin
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The carvings read like prayers, but more like a ban on what later generations may mention."
  - note: "\u591A\u6B21-\u5965\u65AF\u6C40"
    minCount: 2
    maxCount: 2
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The church was not unaware. They chose to keep the dead forever silent."
  - note: "\u4E09\u6B21-\u65C1\u767D"
    minCount: 3
    maxCount: 3
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The strokes of the prayer begin to weather. Beneath the ice, an earlier line emerges \u2014"
    - speaker: "Narrator"
      portraitKey: 
      text: "Remember them."
  - note: "\u4E09\u6B21-\u5965\u65AF\u6C40\u65B0\u8A93"
    minCount: 3
    maxCount: 3
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "In the name of the Dawnvow Church, I restore their true names."
  - note: "\u56DB\u6B21+-\u7EB8\u7247"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "At the altar's center lies a scrap of charred paper \u2014 as if someone before you laid a page of the register here."
  runStoryFlags:
  - f2_altar_seen
  truthAwards:
  - flag: truth_church_silence
    requireHero: Paladin
    fallbackCount: 2
