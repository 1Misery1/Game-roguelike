  m_Script: {fileID: 11500000, guid: 193f66aaf2c6fcf45966fe657458c1e9, type: 3}
  m_Name: Floor3_PreyCorridor
  m_EditorClassIdentifier: 
  objectId: f3_prey_corridor
  bannerText: "[Investigate] Prey Corridor"
  spawnFloor: 3
  spawnRoomIndex: 1
  spawnOffset: {x: -4, y: 0, z: 0}
  tintColor: {r: 0.15, g: 0.12, b: 0.2, a: 1}
  visualScale: {x: 2, y: 0.8}
  colliderSize: {x: 2, y: 1.4}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "On the walls, the floor, even the ceiling \u2014 strange footprints everywhere."
  - note: "\u9996\u6B21-\u8BFA\u5170"
    minCount: 1
    maxCount: 1
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Like a wolf, yet like a man. The depth is wrong too \u2014 it treads too lightly."
  - note: "\u9996\u6B21-\u975E\u8BFA\u5170"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: Hunter
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Too many, too scattered in direction. As if someone were rehearsing something."
  - note: "\u4E8C\u6B21-\u8BFA\u5170"
    minCount: 2
    maxCount: 2
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You glance back \u2014 in the dust behind you, a new trail of prints has appeared."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "That wasn't there a moment ago."
  - note: "\u4E09\u6B21-\u8BFA\u5170"
    minCount: 3
    maxCount: 3
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "It's been behind me the whole time."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The Void is not prey. It's learning how to be the hunter."
  - note: "\u56DB\u6B21+-\u65C1\u767D"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The prints are shallower than before. As if it, too, has begun to hesitate whether to keep chasing."
  - note: "\u56DB\u6B21+-\u8BFA\u5170\u653E\u4E0B"
    minCount: 4
    maxCount: 0
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "You've followed me too long. It's my turn to learn \u2014 to stop chasing."
  runStoryFlags:
  - f3_prey_seen
  truthAwards:
  - flag: truth_void_predator
