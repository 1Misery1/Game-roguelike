  m_Script: {fileID: 11500000, guid: 193f66aaf2c6fcf45966fe657458c1e9, type: 3}
  m_Name: Floor1_ArtisanCorpse
  m_EditorClassIdentifier: 
  objectId: f1_artisan_corpse
  bannerText: "[Investigate] Ashen Artisan's Corpse"
  spawnFloor: 1
  spawnRoomIndex: 2
  spawnOffset: {x: 3, y: -2, z: 0}
  tintColor: {r: 0.18, g: 0.13, b: 0.1, a: 1}
  visualScale: {x: 1.2, y: 0.7}
  colliderSize: {x: 1.2, y: 0.9}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "A charred corpse, half-kneeling. Its hands are curled, fingertips reaching toward the sealed iron door."
  - note: "\u9996\u6B21-\u5965\u65AF\u6C40\u7948\u7977"
    minCount: 1
    maxCount: 1
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "May you rest in a brighter place."
    - speaker: "Wraith Remnant"
      portraitKey: 
      text: "We did not die in the fire."
    - speaker: "Wraith Remnant"
      portraitKey: 
      text: "We died before the door that would not open."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The register in his sleeve survived \u2014 it bears the names of every victim on the first floor."
  - note: "\u9996\u6B21-\u975E\u5965\u65AF\u6C40"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: Paladin
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "He did not die in the fire. He died before that door."
  - note: "\u591A\u6B21-\u65C1\u767D"
    minCount: 2
    maxCount: 2
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The charred fingers still point at the door. As if to say it once more."
  - note: "\u4E09\u6B21-\u65C1\u767D"
    minCount: 3
    maxCount: 3
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The charred fingers tremble faintly. A flake of ash falls from a knuckle \u2014 and does not scatter at once."
  - note: "\u4E09\u6B21-\u5965\u65AF\u6C40\u627F\u8BFA"
    minCount: 3
    maxCount: 3
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I will read out the names in the register, one by one."
  - note: "\u56DB\u6B21+-\u6DE1\u51FA"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The artisan's outline is fainter than last time. As if he can finally leave."
  runStoryFlags:
  - f1_artisan_seen
  truthAwards:
