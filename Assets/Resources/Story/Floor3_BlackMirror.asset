    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "\u955C\u4E2D\u7684\u4F60"
      portraitKey: '{heroKey}'
      text: "\u300C\u4F60\u8BF4\u8981\u51C0\u5316\u90AA\u6076\uFF0C\u53EF\u4F60\u6562\u51C0\u5316\u81EA\u5DF1\u7684\u4FE1\u4EF0\u5417\uFF1F\u300D"
  - note: "\u9996\u6B21-\u8BFA\u5170\u5206\u8EAB"
