    - speaker: "\u955C\u4E2D\u7684\u4F60"
      portraitKey: '{heroKey}'
      text: "\u300C\u4F60\u538C\u6076\u5BFC\u5E08\uFF0C\u4F46\u4F60\u4E5F\u60F3\u77E5\u9053\u7B54\u6848\u3002\u300D"
