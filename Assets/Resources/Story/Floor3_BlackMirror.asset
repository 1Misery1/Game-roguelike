%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 193f66aaf2c6fcf45966fe657458c1e9, type: 3}
  m_Name: Floor3_BlackMirror
  m_EditorClassIdentifier: 
  objectId: f3_black_mirror
  bannerText: "[Investigate] Black Mirror"
  spawnFloor: 3
  spawnRoomIndex: 2
  spawnOffset: {x: 3, y: -2, z: 0}
  tintColor: {r: 0.05, g: 0.05, b: 0.08, a: 1}
  visualScale: {x: 1.4, y: 2.4}
  colliderSize: {x: 1.4, y: 2}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The mirror reflects no light, yet shows a 'you' whose every motion lags half a beat behind."
  - note: "\u9996\u6B21-\u96F7\u6602\u5206\u8EAB"
    minCount: 1
    maxCount: 1
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "The You in the Mirror"
      portraitKey: '{heroKey}'
      text: "You swing your sword to protect the kingdom \u2014 but whom did the kingdom ever protect?"
  - note: "\u9996\u6B21-\u827E\u8587\u62C9\u5206\u8EAB"
    minCount: 1
    maxCount: 1
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "The You in the Mirror"
      portraitKey: '{heroKey}'
      text: "You're not a survivor; you're just the one left behind to remember the pain."
  - note: "\u9996\u6B21-\u8D5B\u7433\u5A1C\u5206\u8EAB"
    minCount: 1
    maxCount: 1
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "The You in the Mirror"
      portraitKey: '{heroKey}'
      text: "You loathe your mentor, yet you too crave the answer."
  - note: "\u9996\u6B21-\u5965\u65AF\u6C40\u5206\u8EAB"
    minCount: 1
    maxCount: 1
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "The You in the Mirror"
      portraitKey: '{heroKey}'
      text: "You say you'll purify evil \u2014 but dare you purify your own faith?"
  - note: "\u9996\u6B21-\u8BFA\u5170\u5206\u8EAB"
    minCount: 1
    maxCount: 1
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "The You in the Mirror"
      portraitKey: '{heroKey}'
      text: "Hunter and prey are but one turn apart."
  - note: "\u591A\u6B21-\u65C1\u767D"
    minCount: 2
    maxCount: 2
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The shadow in the mirror is still there. It grows ever more like you."
  - note: "\u4E09\u6B21-\u96F7\u6602\u548C\u89E3"
    minCount: 3
    maxCount: 3
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "The You in the Mirror"
      portraitKey: '{heroKey}'
      text: "\u2026perhaps you are the true guardian after all."
  - note: "\u4E09\u6B21-\u827E\u8587\u62C9\u548C\u89E3"
    minCount: 3
    maxCount: 3
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "The You in the Mirror"
      portraitKey: '{heroKey}'
      text: "You escaped once; this time you stay. That's only fair."
  - note: "\u4E09\u6B21-\u8D5B\u7433\u5A1C\u548C\u89E3"
    minCount: 3
    maxCount: 3
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "The You in the Mirror"
      portraitKey: '{heroKey}'
      text: "Answer and cost. At last you can tell them apart."
  - note: "\u4E09\u6B21-\u5965\u65AF\u6C40\u548C\u89E3"
    minCount: 3
    maxCount: 3
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "The You in the Mirror"
      portraitKey: '{heroKey}'
      text: "Holiness isn't something guarded. It's something acknowledged."
  - note: "\u4E09\u6B21-\u8BFA\u5170\u548C\u89E3"
    minCount: 3
    maxCount: 3
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "The You in the Mirror"
      portraitKey: '{heroKey}'
      text: "Turn around. This time, you are the hunter."
  - note: "\u56DB\u6B21+-\u955C\u9762\u5316\u6C34"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The mirror dissolves like water, along with the shadow that studied you too long."
  runStoryFlags:
  - f3_mirror_seen
  truthAwards:
  - flag: truth_mirror_confronted
    requireHero: 
    fallbackCount: 0
  grantStoryItems:
  - "Void Memory Shard"
  addCorruption: 4
  choices:
  - label: "Confront"
    description: "Face the you in the mirror \u2014 touch the Void more deeply, but gain the Memory of Confrontation"
    followLines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The two of you stare for a long while. At last the shadow nods gently and returns into the mirror."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I see you. And you see me."
    runStoryFlags:
    - f3_mirror_confronted_self
    truthAwards: []
    grantStoryItems:
    - "Memory of Confrontation"
    addCorruption: 2
    bannerOverride: "[Choice] You confronted the you in the mirror"
  - label: "Turn Away"
    description: "Refuse the encounter \u2014 keep your Restraint; minor purification, but you won't gain the Memory of Confrontation"
    followLines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You turn and walk away. No footsteps follow \u2014 but you know it's been watching all along."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Not every confrontation has to happen."
    runStoryFlags:
    - f3_mirror_refused_self
    truthAwards: []
    grantStoryItems:
    - "Restraint"
    addCorruption: -4
    bannerOverride: "[Choice] You turned away from the mirror"
  choiceTitle: "The 'you' in the mirror lifts its head \u2014"
