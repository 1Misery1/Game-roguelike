    - speaker: "\u955C\u4E2D\u7684\u4F60"
      portraitKey: '{heroKey}'
      text: "\u300C\u4F60\u4E0D\u662F\u5E78\u5B58\u8005\uFF0C\u4F60\u53EA\u662F\u88AB\u7559\u4E0B\u6765\u8BB0\u4F4F\u75DB\u82E6\u7684\u4EBA\u3002\u300D"
