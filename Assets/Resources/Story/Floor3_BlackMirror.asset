      portraitKey: '{heroKey}'
      text: "\u300C\u4F60\u6325\u5251\u4FDD\u62A4\u738B\u56FD\uFF0C\u53EF\u738B\u56FD\u4FDD\u62A4\u8FC7\u8C01\uFF1F\u300D"
