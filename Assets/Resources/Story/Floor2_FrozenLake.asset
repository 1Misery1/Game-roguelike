    maxRunCount: 0
    lines:
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u811A\u4E0B\u7684\u9ED1\u8272\u51B0\u9762\uFF0C\u6620\u51FA\u4E00\u6BB5\u4F60\u4E0D\u613F\u9762\u5BF9\u7684\u753B\u9762\u3002"
  - note: "\u9996\u6B21-\u96F7\u6602"
    minCount: 1
    maxCount: 1
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u2026\u2026\u662F\u7956\u7236\u3002\u4ED6\u5728\u7194\u5CA9\u95E8\u5916\uFF0C\u628A\u5C01\u9501\u4EE4\u9012\u7ED9\u526F\u5B98\u3002"
  - note: "\u9996\u6B21-\u827E\u8587\u62C9"
    minCount: 1
    maxCount: 1
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u6211\u51B2\u51FA\u51B0\u95E8\uFF0C\u8F6C\u8EAB\u2014\u2014\u8EAB\u540E\u7684\u4EBA\u6CA1\u8DDF\u4E0A\u6765\u3002"
  - note: "\u9996\u6B21-\u8D5B\u7433\u5A1C"
    minCount: 1
    maxCount: 1
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u5BFC\u5E08\u8FD8\u5728\u7FFB\u5B9E\u9A8C\u8BB0\u5F55\u3002\u4ED6\u770B\u5230\u4E86\u8B66\u544A\uFF0C\u4F46\u6CA1\u6709\u505C\u624B\u3002"
  - note: "\u9996\u6B21-\u5965\u65AF\u6C40"
    minCount: 1
    maxCount: 1
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u6559\u4F1A\u7684\u706B\u76C6\u2014\u2014\u4ED6\u4EEC\u711A\u70E7\u7684\u662F\u5199\u6EE1\u540D\u5B57\u7684\u518C\u5B50\u3002"
  - note: "\u9996\u6B21-\u8BFA\u5170"
    minCount: 1
    maxCount: 1
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u4E00\u53EA\u91CE\u517D\uFF0C\u773C\u91CC\u6709\u5149\u3002\u5B83\u7B2C\u4E00\u6B21\u300C\u8BA4\u8BC6\u300D\u4EBA\u7C7B\u3002"
  - note: "\u591A\u6B21-\u65C1\u767D"
    minCount: 2
    maxCount: 2
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u4F60\u518D\u6B21\u671B\u5411\u6E56\u9762\u3002\u8FD9\u6B21\uFF0C\u753B\u9762\u53EA\u662F\u7F13\u6162\u5730\u8361\u5F00\u3002"
  - note: "\u4E09\u6B21-\u96F7\u6602"
    minCount: 3
    maxCount: 3
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u955C\u4E2D\u7684\u6211\u5DF2\u7ECF\u653E\u4E0B\u4E86\u5BB6\u5FBD\u3002\u6BD4\u60F3\u8C61\u4E2D\u8F7B\u3002"
  - note: "\u4E09\u6B21-\u827E\u8587\u62C9"
    minCount: 3
    maxCount: 3
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u6211\u6CA1\u6709\u518D\u56DE\u5934\u3002\u4F46\u6BCF\u4E00\u6B65\uFF0C\u90FD\u5E26\u7740\u4ED6\u4EEC\u8D70\u3002"
  - note: "\u4E09\u6B21-\u8D5B\u7433\u5A1C"
    minCount: 3
    maxCount: 3
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u77E5\u8BC6\u4E0D\u662F\u4E3A\u4E86\u80DC\u8FC7\u522B\u4EBA\u3002\u662F\u4E3A\u4E86\u4E0D\u8BA9\u707E\u96BE\u518D\u6765\u4E00\u6B21\u3002"
  - note: "\u4E09\u6B21-\u5965\u65AF\u6C40"
    minCount: 3
    maxCount: 3
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u5723\u6D01\u4E0D\u5728\u796D\u575B\u4E0A\u2014\u2014\u5728\u88AB\u5FD8\u8BB0\u7684\u540D\u5B57\u91CC\u3002"
  - note: "\u4E09\u6B21-\u8BFA\u5170"
    minCount: 3
    maxCount: 3
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u6211\u4E0D\u518D\u8FFD\u51FB\u4EC0\u4E48\u3002\u6211\u5B66\u4F1A\u4E86\u503E\u542C\u3002"
  - note: "\u56DB\u6B21+-\u65C1\u767D"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u6E56\u9762\u7EC8\u4E8E\u5E73\u4E86\u3002\u518D\u4E5F\u6CA1\u6709\u6620\u51FA\u4EFB\u4F55\u4E1C\u897F\u2014\u2014\u53EA\u662F\u4E00\u9762\u6DF1\u5904\u7684\u9ED1\u3002"
