%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 193f66aaf2c6fcf45966fe657458c1e9, type: 3}
  m_Name: Floor2_FrozenLake
  m_EditorClassIdentifier: 
  objectId: f2_frozen_lake
  bannerText: "[Investigate] Frozen Lake"
  spawnFloor: 2
  spawnRoomIndex: 1
  spawnOffset: {x: 0, y: 0.5, z: 0}
  tintColor: {r: 0.05, g: 0.1, b: 0.18, a: 1}
  visualScale: {x: 2.4, y: 2}
  colliderSize: {x: 2.4, y: 1.6}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The black ice underfoot reflects a scene you'd rather not face."
  - note: "\u9996\u6B21-\u96F7\u6602"
    minCount: 1
    maxCount: 1
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u2026it's grandfather. Outside the lava gate, handing the lockdown order to his adjutant."
  - note: "\u9996\u6B21-\u827E\u8587\u62C9"
    minCount: 1
    maxCount: 1
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I rushed out the ice gate and turned \u2014 no one behind me followed."
  - note: "\u9996\u6B21-\u8D5B\u7433\u5A1C"
    minCount: 1
    maxCount: 1
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "My mentor was still leafing through the records. He saw the warning, but did not stop."
  - note: "\u9996\u6B21-\u5965\u65AF\u6C40"
    minCount: 1
    maxCount: 1
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The church braziers \u2014 what they burned were ledgers filled with names."
  - note: "\u9996\u6B21-\u8BFA\u5170"
    minCount: 1
    maxCount: 1
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "A beast, with light in its eyes. For the first time, it 'recognized' humans."
  - note: "\u591A\u6B21-\u65C1\u767D"
    minCount: 2
    maxCount: 2
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You gaze at the lake again. This time the image only slowly ripples away."
  - note: "\u4E09\u6B21-\u96F7\u6602"
    minCount: 3
    maxCount: 3
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The me in the reflection has set down the family crest. Lighter than I imagined."
  - note: "\u4E09\u6B21-\u827E\u8587\u62C9"
    minCount: 3
    maxCount: 3
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I never looked back again. But with every step, I carry them with me."
  - note: "\u4E09\u6B21-\u8D5B\u7433\u5A1C"
    minCount: 3
    maxCount: 3
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Knowledge isn't for surpassing others. It's to keep the disaster from ever happening again."
  - note: "\u4E09\u6B21-\u5965\u65AF\u6C40"
    minCount: 3
    maxCount: 3
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Holiness is not on the altar \u2014 it's in the forgotten names."
  - note: "\u4E09\u6B21-\u8BFA\u5170"
    minCount: 3
    maxCount: 3
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I no longer hunt anything. I've learned to listen."
  - note: "\u56DB\u6B21+-\u65C1\u767D"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The lake finally stills. It reflects nothing anymore \u2014 only a depthless black."
  runStoryFlags:
  - f2_lake_seen
  truthAwards:
  - flag: truth_lake_witnessed
    requireHero: 
    fallbackCount: 0
  grantStoryItems: []
  addCorruption: 2
  choices:
  - label: "Gaze into the Lake"
    description: "Watch every scene you dread to the end \u2014 and bear it"
    followLines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You force yourself to watch to the end. Something cold gently pierces your chest."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Once you see clearly, there's no need to look back."
    runStoryFlags:
    - f2_lake_witnessed_directly
    truthAwards: []
    grantStoryItems:
    - "Frost Mirror Shard"
    addCorruption: 0
    bannerOverride: "[Choice] You gazed into the lake"
  - label: "Shatter the Lake"
    description: "Refuse to watch further \u2014 take something from beneath the shards (corruption rises)"
    followLines:
    - speaker: "Narrator"
      portraitKey: 
      text: "A glassy crack rings out. From the lakebed rises a relic cold to the bone \u2014 you don't know whom it once belonged to."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I don't want to look anymore. This time, let it be."
    runStoryFlags:
    - f2_lake_shattered
    truthAwards: []
    grantStoryItems:
    - "Lakebed Relic"
    addCorruption: 5
    bannerOverride: "[Choice] You shattered the lake"
  choiceTitle: "How will you face this lake?"
