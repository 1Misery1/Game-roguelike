  - label: "\u6253\u788E\u6E56\u9762"
    description: "\u62D2\u7EDD\u518D\u770B\u4E0B\u53BB\u2014\u2014\u4ECE\u788E\u7247\u4E0B\u53D6\u8D70\u67D0\u7269\uFF08\u6C61\u67D3\u52A0\u91CD\uFF09"
    followLines:
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u73BB\u7483\u822C\u7684\u88C2\u58F0\u54CD\u8D77\u3002\u6E56\u5E95\u6D6E\u8D77\u4E00\u4EF6\u51C9\u5230\u9AA8\u5B50\u7684\u9057\u7269\u2014\u2014\u4F60\u4E0D\u77E5\u9053\u90A3\u539F\u672C\u5C5E\u4E8E\u8C01\u3002"
    - speaker: '{hero}'
