  m_Script: {fileID: 11500000, guid: 193f66aaf2c6fcf45966fe657458c1e9, type: 3}
  m_Name: Floor3_Observatory
  m_EditorClassIdentifier: 
  objectId: f3_observatory
  bannerText: "[Investigate] Lightless Observatory"
  spawnFloor: 3
  spawnRoomIndex: 0
  spawnOffset: {x: 3.8, y: 2.6, z: 0}
  tintColor: {r: 0.22, g: 0.16, b: 0.32, a: 1}
  visualScale: {x: 1.8, y: 1.4}
  colliderSize: {x: 1.8, y: 1.4}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "Shattered star charts and observation instruments. A journal still lies open on the desk."
  - note: "\u9996\u6B21-\u8D5B\u7433\u5A1C"
    minCount: 1
    maxCount: 1
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "My mentor's final entry \u2014"
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The Void is not emptiness. It is watching us."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "It has learned our language, our fears, and our desires."
  - note: "\u9996\u6B21-\u975E\u8D5B\u7433\u5A1C"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: Mage
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Runes and star charts. I can't read them, but they're filled with terror."
  - note: "\u4E8C\u6B21-\u8D5B\u7433\u5A1C"
    minCount: 2
    maxCount: 2
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "On the back of the journal is one more line \u2014"
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The request to halt the experiment was denied by the crown. Reason: the kingdom needs eternal energy."
  - note: "\u4E09\u6B21-\u65C1\u767D"
    minCount: 3
    maxCount: 3
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The broken instruments flash one last time. A blank cell on the star chart \u2014 lights up for a second."
  - note: "\u4E09\u6B21-\u8D5B\u7433\u5A1C\u6289\u62E9"
    minCount: 3
    maxCount: 3
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I'll make these records public. Let knowledge no longer crown the throne."
  - note: "\u56DB\u6B21+-\u6C89\u5BC2"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The observatory never responds again. But you already know what it said."
