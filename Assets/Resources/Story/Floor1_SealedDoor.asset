%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 193f66aaf2c6fcf45966fe657458c1e9, type: 3}
  m_Name: Floor1_SealedDoor
  m_EditorClassIdentifier: 
  objectId: f1_sealed_door
  bannerText: "[Investigate] The Sealed Lift Door"
  spawnFloor: 1
  spawnRoomIndex: 0
  spawnOffset: {x: 3.8, y: 2.6, z: 0}
  tintColor: {r: 0.4, g: 0.39, b: 0.46, a: 1}
  visualScale: {x: 1.5, y: 2.7}
  colliderSize: {x: 1.5, y: 1.25}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "A massive iron door blocks the lift shaft, branded with the kingdom's seal."
    - speaker: "Narrator"
      portraitKey: 
      text: "The door was locked from the outside \u2014 in the gap, a charred handprint is frozen in place."
  - note: "\u9996\u6B21-\u96F7\u6602\u4E13\u5C5E"
    minCount: 1
    maxCount: 1
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "This seal\u2026 it is the royal guard's door-sealing craft."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Only an officer had the authority to order it. What trapped the people below was no monster \u2014 it was our own men, locking the door from outside."
  - note: "\u9996\u6B21-\u975E\u96F7\u6602"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: Warrior
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The door was locked from outside. The people within could never escape."
  - note: "\u91CD\u590D-\u65C1\u767D+\u56DE\u58F0"
    minCount: 2
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You lean close to the cold iron again. From behind it, voices seem to seep through the years \u2014"
    - speaker: "Echo Behind the Door"
      portraitKey: 
      text: "Open the door! There are still people alive down here!"
    - speaker: "Echo Behind the Door"
      portraitKey: 
      text: "The order is to seal it. Opening is forbidden."
  - note: "\u91CD\u590D-\u96F7\u6602\u611F\u53F9"
    minCount: 2
    maxCount: 0
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u2026who, exactly, gave this order."
  - note: "\u4E8C\u5468\u76EE-\u95E8\u540E\u589E\u6BB5"
    minCount: 1
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 1
    maxRunCount: 0
    lines:
    - speaker: "Echo Behind the Door"
      portraitKey: 
      text: "\u2026is anyone still there?"
    - speaker: "Echo Behind the Door"
      portraitKey: 
      text: "Please remember our names \u2014"
  - note: "\u4E09\u6B21-\u95E8\u540E\u6258\u4ED8"
    minCount: 3
    maxCount: 3
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "This time there is no roar behind the door, only a deeper silence \u2014"
    - speaker: "Echo Behind the Door"
      portraitKey: 
      text: "\u2026if you can hear us, speak for us."
  - note: "\u4E09\u6B21-\u96F7\u6602\u90D1\u91CD\u627F\u8BFA"
    minCount: 3
    maxCount: 3
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I will. I will speak for you, until no one can feign deafness again."
  - note: "\u56DB\u6B21+-\u6C89\u9ED8\u544A\u522B"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You press your hand to the iron door. No voice answers this time \u2014 but you know they heard you."
  runStoryFlags:
  - f1_sealed_door_seen
  truthAwards:
  - flag: truth_kingdom_sealed_door
    requireHero: Warrior
    fallbackCount: 2
  grantStoryItems: []
  addCorruption: 0
  choices:
  - label: "Break It Open"
    description: "Vent your rage by force (the seal holds firm, but you leave an echo)"
    followLines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You strike once, twice, ten times. The door only hurls your rage back at you."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Damn it. Damn it."
    runStoryFlags:
    - f1_door_struck
    truthAwards: []
    grantStoryItems:
    - "Echo of Fury"
    addCorruption: 3
    bannerOverride: "[Choice] You struck the iron door"
  - label: "Leave in Silence"
    description: "Make remembrance a vow (minor purification)"
    followLines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You release your hand from the cold iron and do not look back. You will remember."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I will speak for you. Starting today."
    runStoryFlags:
    - f1_door_oath
    truthAwards: []
    grantStoryItems:
    - "Memory Pact"
    addCorruption: -2
    bannerOverride: "[Choice] You made a silent vow"
  choiceTitle: "How will you face this door?"
