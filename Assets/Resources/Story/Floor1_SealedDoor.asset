  objectId: f1_sealed_door
  bannerText: "\u3010\u8C03\u67E5\u3011\u5C01\u6B7B\u7684\u5347\u964D\u95E8"
  spawnFloor: 1
  spawnRoomIndex: 0
  spawnOffset: {x: 3.8, y: 2.6, z: 0}
  tintColor: {r: 0.4, g: 0.39, b: 0.46, a: 1}
  visualScale: {x: 1.5, y: 2.7}
  colliderSize: {x: 1.5, y: 1.25}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u4E00\u6247\u5DE8\u5927\u7684\u94C1\u95E8\u6A2A\u5728\u5347\u964D\u4E95\u524D\uFF0C\u95E8\u4E0A\u70D9\u7740\u738B\u56FD\u7684\u5C01\u5370\u3002"
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u94C1\u95E8\u4ECE\u5916\u4FA7\u88AB\u9501\u6B7B\u2014\u2014\u95E8\u7F1D\u91CC\uFF0C\u51DD\u56FA\u7740\u4E00\u53EA\u70E7\u7126\u7684\u624B\u5370\u3002"
  - note: "\u9996\u6B21-\u96F7\u6602\u4E13\u5C5E"
    minCount: 1
    maxCount: 1
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u8FD9\u5C01\u5370\u2026\u2026\u662F\u738B\u56FD\u5B88\u536B\u519B\u7684\u5C01\u95E8\u672F\u3002"
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u53EA\u6709\u519B\u5B98\u624D\u6709\u6743\u4E0B\u4EE4\u4F7F\u7528\u3002\u5F53\u5E74\u56F0\u4F4F\u4E0B\u9762\u90A3\u4E9B\u4EBA\u7684\u4E0D\u662F\u602A\u7269\u2014\u2014\u662F\u6211\u4EEC\u7684\u4EBA\uFF0C\u4ECE\u5916\u9762\u9501\u6B7B\u4E86\u95E8\u3002"
  - note: "\u9996\u6B21-\u975E\u96F7\u6602"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: Warrior
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u95E8\u662F\u4ECE\u5916\u9762\u9501\u4E0A\u7684\u3002\u91CC\u9762\u7684\u4EBA\uFF0C\u6839\u672C\u9003\u4E0D\u51FA\u6765\u3002"
  - note: "\u91CD\u590D-\u65C1\u767D+\u56DE\u58F0"
    minCount: 2
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u4F60\u518D\u6B21\u8D34\u8FD1\u51B0\u51B7\u7684\u94C1\u95E8\u3002\u95E8\u540E\uFF0C\u4EFF\u4F5B\u6709\u58F0\u97F3\u7A7F\u8FC7\u5C81\u6708\u6E17\u4E86\u51FA\u6765\u2014\u2014"
    - speaker: "\u95E8\u540E\u7684\u56DE\u58F0"
      portraitKey: 
      text: "\u300C\u5F00\u95E8\uFF01\u4E0B\u9762\u8FD8\u6709\u6D3B\u4EBA\uFF01\u300D"
    - speaker: "\u95E8\u540E\u7684\u56DE\u58F0"
      portraitKey: 
      text: "\u300C\u547D\u4EE4\u662F\u5C01\u9501\u3002\u4E0D\u51C6\u5F00\u542F\u3002\u300D"
  - note: "\u91CD\u590D-\u96F7\u6602\u611F\u53F9"
    minCount: 2
    maxCount: 0
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u2026\u2026\u8FD9\u9053\u547D\u4EE4\uFF0C\u7A76\u7ADF\u662F\u8C01\u4E0B\u7684\u3002"
  - note: "\u4E8C\u5468\u76EE-\u95E8\u540E\u589E\u6BB5"
    minCount: 1
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 1
    maxRunCount: 0
    lines:
    - speaker: "\u95E8\u540E\u7684\u56DE\u58F0"
      portraitKey: 
      text: "\u300C\u2026\u2026\u8FD8\u6709\u4EBA\u5417\uFF1F\u300D"
    - speaker: "\u95E8\u540E\u7684\u56DE\u58F0"
      portraitKey: 
      text: "\u300C\u8BF7\u8BB0\u4F4F\u6211\u4EEC\u7684\u540D\u5B57\u2014\u2014\u300D"
  - note: "\u4E09\u6B21-\u95E8\u540E\u6258\u4ED8"
    minCount: 3
    maxCount: 3
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u95E8\u540E\u8FD9\u4E00\u6B21\u6CA1\u6709\u6012\u543C\uFF0C\u53EA\u6709\u66F4\u6DF1\u7684\u6C89\u9ED8\u2014\u2014"
    - speaker: "\u95E8\u540E\u7684\u56DE\u58F0"
      portraitKey: 
      text: "\u300C\u2026\u2026\u5982\u679C\u4F60\u542C\u5F97\u5230\uFF0C\u8BF7\u66FF\u6211\u4EEC\u8BF4\u3002\u300D"
  - note: "\u4E09\u6B21-\u96F7\u6602\u90D1\u91CD\u627F\u8BFA"
    minCount: 3
    maxCount: 3
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u6211\u4F1A\u7684\u3002\u4F1A\u66FF\u4F60\u4EEC\u8BF4\uFF0C\u76F4\u5230\u6CA1\u6709\u4EBA\u80FD\u518D\u88C5\u804B\u3002"
  - note: "\u56DB\u6B21+-\u6C89\u9ED8\u544A\u522B"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u4F60\u4F38\u624B\u6309\u5728\u94C1\u95E8\u4E0A\u3002\u8FD9\u4E00\u6B21\u6CA1\u6709\u4EFB\u4F55\u58F0\u97F3\u56DE\u6765\u2014\u2014\u4F46\u4F60\u77E5\u9053\uFF0C\u4ED6\u4EEC\u542C\u89C1\u4E86\u3002"
