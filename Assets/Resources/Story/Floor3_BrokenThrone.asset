      text: "\u4F60\u6276\u4F4F\u65AD\u88C2\u7684\u738B\u5EA7\u8FB9\u7F18\uFF0C\u6307\u8179\u8E6D\u5230\u4E00\u884C\u4E0D\u5728\u663E\u773C\u5904\u7684\u5C0F\u5B57\u2014\u2014"
    - speaker: "\u738B\u5EA7\u6697\u523B"
