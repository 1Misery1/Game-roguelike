%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 193f66aaf2c6fcf45966fe657458c1e9, type: 3}
  m_Name: Floor3_BrokenThrone
  m_EditorClassIdentifier: 
  objectId: f3_broken_throne
  bannerText: "[Investigate] Broken Throne"
  spawnFloor: 3
  spawnRoomIndex: 3
  spawnOffset: {x: 0, y: 3, z: 0}
  tintColor: {r: 0.42, g: 0.32, b: 0.12, a: 1}
  visualScale: {x: 2, y: 2.4}
  colliderSize: {x: 2, y: 2}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The broken throne lies buried at the corridor's end. On its back, gilded letters have not fully faded."
  - note: "\u9996\u6B21-\u738B\u5EA7\u94ED\u6587"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Throne Inscription"
      portraitKey: 
      text: "If thousands below are sacrificed, the capital is secured for a century."
    - speaker: "Throne Inscription"
      portraitKey: 
      text: "This is the kingdom's necessary sin."
  - note: "\u9996\u6B21-\u96F7\u6602"
    minCount: 1
    maxCount: 0
    requireHero: Warrior
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u2026the order my grandfather carried out was this very one."
  - note: "\u9996\u6B21-\u827E\u8587\u62C9"
    minCount: 1
    maxCount: 0
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "My comrades \u2014 they did not die by accident."
  - note: "\u9996\u6B21-\u8D5B\u7433\u5A1C"
    minCount: 1
    maxCount: 0
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The academy's archives\u2026 all whitewashed copies."
  - note: "\u9996\u6B21-\u5965\u65AF\u6C40"
    minCount: 1
    maxCount: 0
    requireHero: Paladin
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The church's prayers were a requiem sung for this stone."
  - note: "\u9996\u6B21-\u8BFA\u5170"
    minCount: 1
    maxCount: 0
    requireHero: Hunter
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The corruption didn't crawl up from the earth. Someone let it loose."
  - note: "\u4E8C\u6B21-\u6697\u523B"
    minCount: 2
    maxCount: 2
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You steady yourself on the broken throne's edge; your fingertip brushes a small line of text tucked out of sight \u2014"
    - speaker: "Hidden Throne Engraving"
      portraitKey: 
      text: "In the name of the thousands below, we crown ourselves."
  - note: "\u4E09\u6B21-\u5D29\u584C"
    minCount: 3
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You approach the throne one last time. This time it no longer holds \u2014 the gilt peels, the stone splits open, as if yielding its place."
  runStoryFlags:
  - f3_throne_seen
  truthAwards:
  - flag: truth_kingdom_guilt
    requireHero: 
    fallbackCount: 0
  grantStoryItems: []
  addCorruption: 0
  choices:
  - label: "Sit Upon It"
    description: "Crown yourself for a moment (massive corruption, but gain Throne's Lingering Might)"
    followLines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You sit down. The stone is warmer than you expected \u2014 as if someone sat here long, and long refused to yield."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "So that's it. So this is how it feels."
    runStoryFlags:
    - f3_throne_sat
    truthAwards: []
    grantStoryItems:
    - "Throne's Lingering Might"
    addCorruption: 6
    bannerOverride: "[Choice] You sat upon the throne"
  - label: "Topple It"
    description: "Let the throne collapse entirely (purifies corruption, gain the Courage to Overthrow)"
    followLines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You shove forward with all your strength. The base shatters first, the backrest topples after \u2014 the gilt drifts into the dark like a cloud of kindled ash."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "This kick is for the thousands below."
    runStoryFlags:
    - f3_throne_toppled
    truthAwards: []
    grantStoryItems:
    - "Courage to Overthrow"
    addCorruption: -3
    bannerOverride: "[Choice] You toppled the throne"
  choiceTitle: "What will you do with this throne?"
