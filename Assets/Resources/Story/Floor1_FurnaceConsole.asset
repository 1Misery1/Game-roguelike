  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 193f66aaf2c6fcf45966fe657458c1e9, type: 3}
  m_Name: Floor1_FurnaceConsole
  m_EditorClassIdentifier: 
  objectId: f1_furnace_console
  bannerText: "[Investigate] Forge Console"
  spawnFloor: 1
  spawnRoomIndex: 1
  spawnOffset: {x: -3.5, y: 1.5, z: 0}
  tintColor: {r: 0.55, g: 0.28, b: 0.18, a: 1}
  visualScale: {x: 1.4, y: 1}
  colliderSize: {x: 1.4, y: 1}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "A rusted mechanical console stands at the center of the forge hall. Its needle is still stuck on a set of glaring numbers \u2014"
    - speaker: "Narrator"
      portraitKey: 
      text: "Worldcore extraction rate: 327%. Cooling-system warning ignored."
  - note: "\u9996\u6B21-\u8D5B\u7433\u5A1C\u4E13\u5C5E"
    minCount: 1
    maxCount: 1
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "This machine isn't broken \u2014 someone deliberately drove it past its limit."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Keep refining, until the capital's main energy tower is complete."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "The disaster was no accident. The kingdom forcibly overloaded the worldcore for energy."
  - note: "\u9996\u6B21-\u975E\u8D5B\u7433\u5A1C"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: Mage
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I can't read these gauges, but every dial is buried in the red."
  - note: "\u591A\u6B21-\u65C1\u767D"
    minCount: 2
    maxCount: 2
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "You touch the broken lever; the console flickers briefly, then goes dark again."
  - note: "\u4E09\u6B21-\u65C1\u767D"
    minCount: 3
    maxCount: 3
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The console lights up for a moment, a single line flashing past \u2014"
    - speaker: "Narrator"
      portraitKey: 
      text: "\u2026please shut it down."
  - note: "\u4E09\u6B21-\u8D5B\u7433\u5A1C\u6289\u62E9"
    minCount: 3
    maxCount: 3
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I've seen it. I will never again yield to 'necessity'."
  - note: "\u56DB\u6B21+-\u7070\u70EC"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The console falls utterly silent. The needle snaps in two, as if gently pressed down."
  runStoryFlags:
  - f1_furnace_seen
  truthAwards:
  - flag: truth_furnace_overload
    requireHero: Mage
    fallbackCount: 2
