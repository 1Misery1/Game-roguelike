      text: "\u4F60\u89E6\u78B0\u65AD\u88C2\u7684\u62C9\u6746\uFF0C\u63A7\u5236\u53F0\u77ED\u6682\u95EA\u70C1\uFF0C\u53C8\u518D\u6B21\u7184\u706D\u3002"
