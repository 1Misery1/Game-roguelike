  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u9508\u8680\u7684\u673A\u68B0\u63A7\u5236\u53F0\u7ACB\u5728\u953B\u9020\u5927\u5385\u4E2D\u592E\u3002\u6307\u9488\u4ECD\u5361\u5728\u4E00\u7EC4\u523A\u773C\u7684\u6570\u5B57\u4E0A\u2014\u2014"
    - speaker: "\u65C1\u767D"
      portraitKey: 
      text: "\u300C\u754C\u5FC3\u62BD\u53D6\u7387\uFF1A327%\u3002\u51B7\u5374\u7CFB\u7EDF\u8B66\u544A\u5DF2\u5FFD\u7565\u3002\u300D"
  - note: "\u9996\u6B21-\u8D5B\u7433\u5A1C\u4E13\u5C5E"
    minCount: 1
    maxCount: 1
    requireHero: Mage
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u8FD9\u53F0\u673A\u5668\u6CA1\u574F\u2014\u2014\u5B83\u662F\u88AB\u4EBA\u4E3B\u52A8\u903C\u5230\u6781\u9650\u7684\u3002"
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u300C\u7EE7\u7EED\u63D0\u70BC\uFF0C\u76F4\u5230\u738B\u90FD\u4E3B\u80FD\u6E90\u5854\u5B8C\u6210\u3002\u300D"
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u707E\u96BE\u4E0D\u662F\u610F\u5916\u3002\u662F\u738B\u56FD\u4E3A\u4E86\u80FD\u6E90\uFF0C\u5F3A\u884C\u8D85\u8F7D\u754C\u5FC3\u3002"
  - note: "\u9996\u6B21-\u975E\u8D5B\u7433\u5A1C"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: Mage
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u6211\u770B\u4E0D\u61C2\u8FD9\u4E9B\u8BFB\u6570\uFF0C\u4F46\u6BCF\u4E2A\u8868\u5934\u90FD\u9876\u8FDB\u4E86\u7EA2\u533A\u3002"
  - note: "\u591A\u6B21-\u65C1\u767D"
    minCount: 2
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
