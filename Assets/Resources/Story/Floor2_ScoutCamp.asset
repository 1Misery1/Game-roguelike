MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 193f66aaf2c6fcf45966fe657458c1e9, type: 3}
  m_Name: Floor2_ScoutCamp
  m_EditorClassIdentifier: 
  objectId: f2_scout_camp
  bannerText: "[Investigate] Frozen Scout Camp"
  spawnFloor: 2
  spawnRoomIndex: 0
  spawnOffset: {x: 3.8, y: 2.6, z: 0}
  tintColor: {r: 0.55, g: 0.75, b: 0.85, a: 1}
  visualScale: {x: 1.7, y: 1.6}
  colliderSize: {x: 1.7, y: 1.6}
  branches:
  - note: "\u9996\u6B21-\u65C1\u767D"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "A few frozen-stiff tents form a half-circle; the campfire long dead. A quiver juts from the snow."
  - note: "\u9996\u6B21-\u827E\u8587\u62C9"
    minCount: 1
    maxCount: 1
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "These fletchings\u2026 they're our squad's mark."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "They were here all along. No one ever came back for them."
  - note: "\u9996\u6B21-\u975E\u827E\u8587\u62C9"
    minCount: 1
    maxCount: 1
    requireHero: 
    forbidHero: Ranger
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "A scouting party that never made it back. The ice kept them where they fell."
  - note: "\u4E8C\u6B21-\u827E\u8587\u62C9\u56DE\u5FC6"
    minCount: 2
    maxCount: 2
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "Blurred figures surface within the ice, like a frozen strip of film."
    - speaker: "Echo Beneath the Ice"
      portraitKey: 
      text: "Elvira \u2014 run, don't look back!"
  - note: "\u4E09\u6B21-\u827E\u8587\u62C9\u771F\u76F8"
    minCount: 3
    maxCount: 3
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "\u2026I finally remember."
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "I didn't abandon them. They closed the ice gate and pushed me out."
  - note: "\u56DB\u6B21+-\u65C1\u767D\u6D88\u878D"
    minCount: 4
    maxCount: 0
    requireHero: 
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: "Narrator"
      portraitKey: 
      text: "The camp's snow begins to melt, little by little. The frozen canvas loosens too."
  - note: "\u56DB\u6B21+-\u827E\u8587\u62C9\u544A\u522B"
    minCount: 4
    maxCount: 0
    requireHero: Ranger
    forbidHero: 
    minRunCount: 0
    maxRunCount: 0
    lines:
    - speaker: '{hero}'
      portraitKey: '{heroKey}'
      text: "Thank you. I carried your names out too."
  runStoryFlags:
  - f2_scout_camp_seen
  truthAwards:
  - flag: truth_scout_sacrifice
    requireHero: Ranger
    fallbackCount: 2
  grantStoryItems: []
  addCorruption: 0
